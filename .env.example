# Application Path
APP_PATH="/path/to/application/source/files"

# Twitch Credentials
TWITCH_CLIENT_ID="your_client_id_here"
TWITCH_CLIENT_SECRET="your_client_secret_here"
TWITCH_EVENTSUB_SECRET="your_eventsub_secret_here"

# SSL Configuration
HOST_NAME="www.example.com"
SSL_PRIVATE_KEY_PATH="/path/to/private/key"
SSL_CERTIFICATE_PATH="/path/to/certificate"

# MySQL Configuration
HOST="hostname_here"
USER="mysql_username_here"
PASSWORD="secure_db_password_here"
DATABASE="db_name_here"
DATABASE_URL="database_url_here"

# JWT Secret generated by command "openssl rand -base64 32" on linux terminal. Database expects a 44-character string.
JWT_REFRESH_SECRET="refresh_secret_here" # Used to create Slither Refresh Tokens
JWT_ACCESS_SECRET="access_secret_here" # Used to create Slither Access Tokens

# Websocket Secrets generated by command "openssl rand -base64 32" on linux terminal. Database expects a 44-character string.
CONTROLLER_WEBSOCKET_SECRET="controller_ws_secret_here"
ALERTS_WEBSOCKET_SECRET="alerts_ws_secret_here"