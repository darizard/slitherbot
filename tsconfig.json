{
    "compilerOptions": {
        "strict": true,
        "outDir": "./built",
        "allowJs": true,
        "target": "esnext",
        "module": "nodenext",
        "noEmitOnError": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext"
    },
    "include": ["./src/**/*"]
}